# ────────────────────────────────────────────────────────────────────────────
# Polaris — environment template
# Copy to `.env`, fill values for local dev.
# NEVER commit `.env`. Production values come from Azure Key Vault, not here.
# ────────────────────────────────────────────────────────────────────────────

# ── Azure ──────────────────────────────────────────────────────────────────
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=
AZURE_CLIENT_ID=                      # OIDC federated identity for GitHub Actions
AZURE_REGION=canadacentral

# ── ADLS Gen2 ──────────────────────────────────────────────────────────────
ADLS_ACCOUNT_NAME=polarisstg
ADLS_CONTAINER_BRONZE=bronze
ADLS_CONTAINER_SILVER=silver
ADLS_CONTAINER_GOLD=gold

# ── Azure Key Vault ────────────────────────────────────────────────────────
KEY_VAULT_NAME=polaris-kv

# ── Snowflake (key-pair auth, no passwords) ────────────────────────────────
SNOWFLAKE_ACCOUNT=                    # e.g. ab12345.ca-central-1.aws
SNOWFLAKE_USER=POLARIS_SVC
SNOWFLAKE_ROLE=POLARIS_DBT_ROLE
SNOWFLAKE_WAREHOUSE=POLARIS_WH_TRANSFORM
SNOWFLAKE_DATABASE=POLARIS
SNOWFLAKE_PRIVATE_KEY_PATH=~/.snowflake/polaris_rsa_key.p8
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# ── Databricks ─────────────────────────────────────────────────────────────
DATABRICKS_HOST=                      # e.g. https://adb-xxx.azuredatabricks.net
DATABRICKS_AUTH_TYPE=oauth            # avoid PATs
DATABRICKS_CLIENT_ID=
# DATABRICKS_CLIENT_SECRET — sourced from Key Vault, not here

# ── Kafka (local docker) ───────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081

# ── Airflow (local docker) ─────────────────────────────────────────────────
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=           # set on first run only

# ── OpenLineage / Marquez ──────────────────────────────────────────────────
OPENLINEAGE_URL=http://localhost:5000
OPENLINEAGE_NAMESPACE=polaris

# ── Alerting ───────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=                    # set in Key Vault for prod
